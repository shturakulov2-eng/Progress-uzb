generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id           String   @id @default(uuid())
  fullName     String
  companyName  String
  businessType String
  phoneNumber  String
  createdAt    DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([companyName])
}
